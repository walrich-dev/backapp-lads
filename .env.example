# Server
PORT=3000
NODE_ENV=development

# Database - PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lads_db?schema=public"

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_strong_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081
